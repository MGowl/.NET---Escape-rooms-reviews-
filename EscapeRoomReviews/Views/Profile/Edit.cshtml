@model EscapeRoomReviews.ViewModels.ProfileEditViewModel

@{
    ViewData["Title"] = "Moj profil";
    var hasExternalLogin = ViewData["HasExternalLogin"] as bool? == true;
}

<div class="mb-4">
    <h1 class="display-6 fw-bold text-primary-custom">Moj profil</h1>
    <p class="text-muted">Uredite svoje podatke.</p>
</div>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        @TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<form asp-action="Edit" method="post" class="card shadow-sm border-0 p-4">
    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

    <div class="mb-3">
        <label asp-for="DisplayName" class="form-label">Prikazno ime <span class="text-muted small">(opcionalno)</span></label>
        <input asp-for="DisplayName" class="form-control" placeholder="Npr. Maja G." />
        <div class="form-text">Ako je prazno, prikazivat će se Ime i Prezime.</div>
        <span asp-validation-for="DisplayName" class="text-danger small"></span>
    </div>

    <div class="mb-3">
        <label asp-for="FirstName" class="form-label">Ime</label>
        <input asp-for="FirstName" class="form-control" />
        <span asp-validation-for="FirstName" class="text-danger small"></span>
    </div>

    <div class="mb-3">
        <label asp-for="LastName" class="form-label">Prezime</label>
        <input asp-for="LastName" class="form-control" />
        <span asp-validation-for="LastName" class="text-danger small"></span>
    </div>

    <div class="mb-4">
        <label asp-for="Email" class="form-label">Email</label>
        @if (hasExternalLogin)
        {
            <input asp-for="Email" class="form-control" readonly />
            <div class="form-text text-muted">Email upravljan putem Google računa.</div>
        }
        else
        {
            <input asp-for="Email" class="form-control" type="email" />
            <span asp-validation-for="Email" class="text-danger small"></span>
        }
    </div>

    <div class="d-flex gap-2">
        <button type="submit" class="btn btn-primary fw-semibold">Spremi promjene</button>
    </div>
</form>
