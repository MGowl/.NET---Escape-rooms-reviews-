@model EscapeRoomReviews.Models.Forms.EscapeRoomEditModel
@using EscapeRoomReviews.Models.Domain

@{
    ViewData["Title"] = "Uredi sobu";
    var locationName = ViewData["LocationName"] as string ?? string.Empty;
    var companyName = ViewData["CompanyName"] as string ?? string.Empty;
    var themes = ViewData["Themes"] as IEnumerable<SelectListItem>
        ?? System.Linq.Enumerable.Empty<SelectListItem>();
}

<div class="mb-4">
    <h1 class="display-6 fw-bold text-primary-custom">Uredi sobu</h1>
    <p class="text-muted">Azurirajte podatke za sobu.</p>
</div>

<form asp-action="Edit" method="post" class="card shadow-sm border-0 p-4">
    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
    <input asp-for="Id" type="hidden" />

    <div class="mb-3">
        <label asp-for="Name" class="form-label">Naziv</label>
        <input asp-for="Name" class="form-control" />
        <span asp-validation-for="Name" class="text-danger small"></span>
    </div>

    <div class="mb-3">
        <label asp-for="Description" class="form-label">Opis</label>
        <textarea asp-for="Description" class="form-control" rows="4"></textarea>
        <span asp-validation-for="Description" class="text-danger small"></span>
    </div>

    <div class="mb-3">
        <label asp-for="Difficulty" class="form-label">Tezina</label>
        <select asp-for="Difficulty" class="form-select" asp-items="Html.GetEnumSelectList<DifficultyLevel>()"></select>
        <span asp-validation-for="Difficulty" class="text-danger small"></span>
    </div>

    <div class="mb-3">
        <label asp-for="MaxPlayers" class="form-label">Max igraca</label>
        <input asp-for="MaxPlayers" class="form-control" type="number" min="1" />
        <span asp-validation-for="MaxPlayers" class="text-danger small"></span>
    </div>

    <div class="mb-3">
        <label asp-for="Price" class="form-label">Cijena</label>
        <input asp-for="Price" class="form-control" type="number" step="0.01" min="0" />
        <span asp-validation-for="Price" class="text-danger small"></span>
    </div>

    @await Html.PartialAsync("_Autocomplete", new AutocompleteViewModel
    {
        FieldName = nameof(Model.LocationId),
        SelectedId = Model.LocationId,
        SelectedName = locationName,
        SearchUrl = Url.Action("SearchLocations", "ManageEscapeRoom") ?? string.Empty,
        Label = "Lokacija",
        Placeholder = "Pretrazi lokaciju...",
        ContainerClass = "mb-3 ajax-autocomplete",
        IsRequired = true,
        RequiredMessage = "Odaberite lokaciju."
    })

    @await Html.PartialAsync("_Autocomplete", new AutocompleteViewModel
    {
        FieldName = nameof(Model.CompanyId),
        SelectedId = Model.CompanyId,
        SelectedName = companyName,
        SearchUrl = Url.Action("SearchCompanies", "ManageEscapeRoom") ?? string.Empty,
        Label = "Tvrtka",
        Placeholder = "Pretrazi tvrtku...",
        ContainerClass = "mb-4 ajax-autocomplete",
        IsRequired = true,
        RequiredMessage = "Odaberite tvrtku."
    })

    <div class="mb-4">
        <label asp-for="ThemeIds" class="form-label">Teme</label>
        <div class="d-flex flex-wrap gap-3">
            @foreach (var theme in themes)
            {
                <div class="form-check">
                    <input class="form-check-input"
                           type="checkbox"
                           name="ThemeIds"
                           value="@theme.Value"
                           id="theme-@theme.Value"
                           data-val="true"
                           data-val-minlength="Odaberite barem jednu temu."
                           data-val-minlength-min="1"
                           @(theme.Selected ? "checked" : null) />
                    <label class="form-check-label" for="theme-@theme.Value">@theme.Text</label>
                </div>
            }
        </div>
        <span asp-validation-for="ThemeIds" class="text-danger small"></span>
        <div class="form-text">Mozes odabrati vise tema klikom na pojedinu temu.</div>
    </div>

    <div class="d-flex gap-2">
        <button type="submit" class="btn btn-primary fw-semibold">Spremi promjene</button>
        <a asp-action="Index" class="btn btn-outline-secondary">Odustani</a>
    </div>
</form>

<div class="mt-4">
    <h5>Fotografije</h5>
    <form id="photoDz"
          asp-controller="ManageEscapeRoom"
          asp-action="UploadPhoto"
          asp-route-escapeRoomId="@Model.Id"
          enctype="multipart/form-data"
          class="dropzone">
    </form>
    <div id="photoList" class="mt-3"></div>
</div>

@section Scripts {
    <link rel="stylesheet" href="~/lib/dropzone/dropzone.min.css" />
    <script src="~/lib/dropzone/dropzone.min.js"></script>
    <script>
        Dropzone.options.photoDz = {
            success: function (file, response) {
                loadPhotos();
            }
        };

        $(function () {
            loadPhotos();
        });

        function loadPhotos() {
            $("#photoList").load("@Url.Action("GetPhotos", "ManageEscapeRoom", new { escapeRoomId = Model.Id })");
        }

        function deletePhoto(id) {
            $.ajax({
                url: "@Url.Action("DeletePhoto", "ManageEscapeRoom")",
                method: "POST",
                data: { id: id },
                success: function () {
                    loadPhotos();
                },
                error: function () {
                    alert("Greška pri brisanju fotografije.");
                }
            });
        }
    </script>
}
