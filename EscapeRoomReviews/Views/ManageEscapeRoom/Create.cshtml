@model EscapeRoomReviews.Models.Forms.EscapeRoomCreateModel
@using EscapeRoomReviews.Models.Domain

@{
    ViewData["Title"] = "Nova soba";
    var locationName = ViewData["LocationName"] as string ?? string.Empty;
    var companyName = ViewData["CompanyName"] as string ?? string.Empty;
    var themes = ViewData["Themes"] as IEnumerable<SelectListItem>
        ?? System.Linq.Enumerable.Empty<SelectListItem>();
}

<div class="mb-4">
    <h1 class="display-6 fw-bold text-primary-custom">Nova soba</h1>
    <p class="text-muted">Unesite podatke za novu sobu.</p>
</div>

<form asp-action="Create" method="post" class="card shadow-sm border-0 p-4">
    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

    <div class="mb-3">
        <label asp-for="Name" class="form-label">Naziv</label>
        <input asp-for="Name" class="form-control" />
        <span asp-validation-for="Name" class="text-danger small"></span>
    </div>

    <div class="mb-3">
        <label asp-for="Description" class="form-label">Opis</label>
        <textarea asp-for="Description" class="form-control" rows="4"></textarea>
        <span asp-validation-for="Description" class="text-danger small"></span>
    </div>

    <div class="mb-3">
        <label asp-for="Difficulty" class="form-label">Tezina</label>
        <select asp-for="Difficulty" class="form-select" asp-items="Html.GetEnumSelectList<DifficultyLevel>()"></select>
        <span asp-validation-for="Difficulty" class="text-danger small"></span>
    </div>

    <div class="mb-3">
        <label asp-for="MaxPlayers" class="form-label">Max igraca</label>
        <input asp-for="MaxPlayers" class="form-control" type="number" min="1" />
        <span asp-validation-for="MaxPlayers" class="text-danger small"></span>
    </div>

    <div class="mb-3">
        <label asp-for="Price" class="form-label">Cijena</label>
        <input asp-for="Price" class="form-control" type="number" step="0.01" min="0" />
        <span asp-validation-for="Price" class="text-danger small"></span>
    </div>

    @await Html.PartialAsync("_Autocomplete", new AutocompleteViewModel
    {
        FieldName = nameof(Model.LocationId),
        SelectedId = Model.LocationId,
        SelectedName = locationName,
        SearchUrl = Url.Action("SearchLocations", "ManageEscapeRoom") ?? string.Empty,
        Label = "Lokacija",
        Placeholder = "Pretrazi lokaciju...",
        ContainerClass = "mb-3 ajax-autocomplete",
        IsRequired = true,
        RequiredMessage = "Odaberite lokaciju."
    })

    @await Html.PartialAsync("_Autocomplete", new AutocompleteViewModel
    {
        FieldName = nameof(Model.CompanyId),
        SelectedId = Model.CompanyId,
        SelectedName = companyName,
        SearchUrl = Url.Action("SearchCompanies", "ManageEscapeRoom") ?? string.Empty,
        Label = "Tvrtka",
        Placeholder = "Pretrazi tvrtku...",
        ContainerClass = "mb-4 ajax-autocomplete",
        IsRequired = true,
        RequiredMessage = "Odaberite tvrtku."
    })

    <div class="mb-4">
        <label asp-for="ThemeIds" class="form-label">Teme</label>
        <div class="d-flex flex-wrap gap-3">
            @foreach (var theme in themes)
            {
                <div class="form-check">
                    <input class="form-check-input" type="checkbox" name="ThemeIds" value="@theme.Value" id="theme-@theme.Value" />
                    <label class="form-check-label" for="theme-@theme.Value">@theme.Text</label>
                </div>
            }
        </div>
        <div class="form-text">Mozes odabrati vise tema klikom na pojedinu temu.</div>
    </div>

    <div class="d-flex gap-2">
        <button type="submit" class="btn btn-primary fw-semibold">Spremi</button>
        <a asp-action="Index" class="btn btn-outline-secondary">Odustani</a>
    </div>
</form>
