@model List<EscapeRoomReviews.Models.Domain.EscapeRoom>

@{
    ViewData["Title"] = "Escape Rooms";
}

<div class="d-flex flex-column flex-sm-row justify-content-between align-items-sm-center mb-4">
    <div>
        <h1 class="display-6 fw-bold text-primary-custom mb-1">Escape Rooms</h1>
        <p class="text-muted mb-0">Administracija soba.</p>
    </div>
    <a asp-action="Create" class="btn btn-primary fw-semibold mt-3 mt-sm-0">
        + Nova soba
    </a>
</div>

<div class="table-responsive">
    <table class="table table-striped align-middle">
        <thead class="table-light">
            <tr>
                <th>Id</th>
                <th>Naziv</th>
                <th>Tezina</th>
                <th>Max igraca</th>
                <th>Cijena</th>
                <th>Lokacija</th>
                <th>Tvrtka</th>
                <th class="text-end">Akcije</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var room in Model)
            {
                <tr>
                    <td>@room.Id</td>
                    <td>@room.Name</td>
                    <td>@room.Difficulty</td>
                    <td>@room.MaxPlayers</td>
                    <td>@room.Price.ToString("0.00")</td>
                    <td>@room.Location?.City</td>
                    <td>@room.Company?.Name</td>
                    <td class="text-end">
                        <a asp-action="Edit" asp-route-id="@room.Id" class="btn btn-sm btn-outline-primary me-2">Edit</a>
                        <form asp-action="Delete" method="post" class="d-inline">
                            <input type="hidden" name="id" value="@room.Id" />
                            <button type="submit" class="btn btn-sm btn-outline-danger">Delete</button>
                        </form>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

@if (!Model.Any())
{
    <div class="alert alert-info">Trenutno nema dostupnih soba.</div>
}
