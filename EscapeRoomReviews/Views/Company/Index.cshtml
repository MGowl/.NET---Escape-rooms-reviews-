@model IEnumerable<EscapeRoomReviews.ViewModels.CompanyIndexViewModel>

@{
    ViewData["Title"] = "Tvrtke";
}

<div class="mb-4">
    <h1 class="display-5 fw-bold" style="color: var(--color-primary);">Tvrtke za escape room</h1>
    <p class="lead text-muted">Pregled svih tvrtki koje nude escape room iskustva.</p>
</div>

<div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4">
    @foreach (var company in Model)
    {
        <div class="col">
            <a asp-action="Details" asp-route-id="@company.Id" style="text-decoration:none; color:inherit;">
                <div class="card h-100 shadow-sm border-0" style="background-color: var(--color-bg-soft); transition: transform 0.2s;">
                    <div class="card-body">
                        <h5 class="card-title fw-bold" style="color: var(--color-primary);">@company.Name</h5>
                        
                        <div class="mb-3 mt-3">
                            <span class="badge rounded-pill" style="background-color: var(--color-accent-cyan); color: #093b3f;">
                                @(company.RoomCount) sobe
                            </span>
                        </div>

                        @if (!string.IsNullOrEmpty(company.Website))
                        {
                            <span class="btn btn-sm text-white mt-auto" style="background-color: var(--color-primary);">Posjeti web &rarr;</span>
                        }
                    </div>
                </div>
            </a>
        </div>
    }
</div>

@if (!Model.Any())
{
    <div class="alert alert-info">Trenutno nema dostupnih tvrtki.</div>
}




