@model IEnumerable<EscapeRoomReviews.ViewModels.CompanyIndexViewModel>

@{
    ViewData["Title"] = "Tvrtke";
}

<div class="mb-4">
    <h1 class="display-5 fw-bold text-primary-custom">Tvrtke za escape room</h1>
    <p class="lead text-muted">Pregled svih tvrtki koje nude escape room iskustva.</p>
</div>

<div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4">
    @foreach (var company in Model)
    {
        <div class="col">
            <a asp-action="Details" asp-route-id="@company.Id" style="text-decoration:none; color:inherit;">
                <div class="card shadow-sm border-0 h-100 bg-white">
                    <div class="card-body">
                        <h5 class="card-title fw-bold text-primary-custom">@company.Name</h5>
                        
                        <div class="mb-3 mt-3">
                            <span class="badge rounded-pill bg-info">
                                @(company.RoomCount) sobe
                            </span>
                        </div>

                        @if (!string.IsNullOrEmpty(company.Website))
                        {
                            <span class="btn btn-primary btn-sm mt-auto">Posjeti web &rarr;</span>
                        }
                    </div>
                </div>
            </a>
        </div>
    }
</div>

@if (!Model.Any())
{
    <div class="alert alert-info">Trenutno nema dostupnih tvrtki.</div>
}

@section Scripts {
    <script>
        document.addEventListener("DOMContentLoaded", function () {
            var rows = document.querySelectorAll(".row");
            if (!rows.length) return;
            var cardsRow = rows[rows.length - 1];
            if (!cardsRow) return;

            var cards = cardsRow.querySelectorAll(".col, [class*='col-']");
            cards.forEach(function (card, index) {
                card.style.animationDelay = (index * 80) + "ms";
                card.classList.add("card-enter");
            });
        });
    </script>
}






