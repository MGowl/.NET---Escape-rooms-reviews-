@using EscapeRoomReviews.Models.Domain
@model Company

@{
    ViewData["Title"] = Model.Name;
    ViewData["BreadcrumbTitle"] = Model.Name;
    ViewData["BreadcrumbParent"] = "Tvrtke";
    ViewData["BreadcrumbParentAction"] = "Index";
    ViewData["BreadcrumbParentController"] = "Company";
}

<div class="container mt-5 mb-5">
    <!-- Header Section -->
    <div class="d-flex justify-content-between align-items-center mb-4 pb-3 border-bottom">
        <div>
            <h1 class="display-5 mb-2 text-primary-custom">@Model.Name</h1>
            @if (!string.IsNullOrEmpty(Model.Website))
            {
                <a href="@Model.Website" class="link-accent fw-medium" target="_blank" rel="noopener noreferrer">
                    <i class="bi bi-box-arrow-up-right me-1"></i> @Model.Website
                </a>
            }
        </div>
        <div>
            <a asp-action="Index" class="btn btn-outline-primary px-4 py-2 rounded-pill fw-medium">
                <i class="bi bi-arrow-left me-1"></i> Back
            </a>
        </div>
    </div>

    <!-- Escape Rooms Section -->
    <h3 class="mb-4 fw-bold text-primary-custom">Escape Rooms by @Model.Name</h3>

    @if (Model.EscapeRooms == null || !Model.EscapeRooms.Any())
    {
        <div class="p-5 text-center rounded-4 shadow-sm" style="background-color: var(--color-bg-page); border-top: 5px solid var(--color-accent-pink);">
            <h4 class="fw-bold mb-3 text-primary-custom">No Rooms Found</h4>
            <p class="text-muted mb-0 fs-5">This company hasn't added any escape rooms to their profile yet.</p>
        </div>
    }
    else
    {
        <div class="row row-cols-1 row-cols-md-2 row-cols-xl-3 g-4">
            @foreach (var room in Model.EscapeRooms)
            {
                <div class="col">
                    <div class="card shadow-sm border-0 h-100 rounded-4 bg-white">
                        <div class="card-body p-4 d-flex flex-column">
                            <div class="d-flex justify-content-between align-items-start mb-3">
                                <h4 class="card-title mb-0 fw-bold text-primary-custom">@room.Name</h4>
                                <span class="badge rounded-pill px-3 py-2 fw-medium bg-primary">
                                    @room.Difficulty
                                </span>
                            </div>
                            
                            <p class="card-text text-muted mb-3 d-flex align-items-center">
                                <i class="bi bi-geo-alt-fill me-2 text-primary-custom"></i> 
                                @(room.Location?.City ?? "Unknown City")
                            </p>

                            <div class="mb-4 border-start border-3 ps-3 py-1" style="border-color: var(--color-accent-peach) !important;">
                                @{
                                    var hasReviews = room.Reviews != null && room.Reviews.Any();
                                    if (hasReviews)
                                    {
                                        var avgRating = room.Reviews!.Average(r => r.Rating);
                                        <div class="d-flex align-items-center">
                                            <span class="fs-5 fw-bold me-2" style="color: #004F32;">
                                                <i class="bi bi-star-fill star-rating"></i> @avgRating.ToString("0.0")
                                            </span>
                                            <span class="text-muted fw-medium">(@room.Reviews.Count reviews)</span>
                                        </div>
                                    }
                                    else
                                    {
                                        <span class="text-muted fst-italic fw-medium">No reviews yet</span>
                                    }
                                }
                            </div>
                            
                            <div class="mt-auto pt-3 border-top d-flex justify-content-between align-items-center">
                                <div class="fw-bold fs-4 text-primary-custom">
                                    $@room.Price.ToString("0.00")
                                </div>
                                <a asp-controller="EscapeRoom" asp-action="Details" asp-route-id="@room.Id" 
                                   class="btn btn-primary rounded-pill px-4 fw-bold shadow-sm">
                                    View Details
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>







