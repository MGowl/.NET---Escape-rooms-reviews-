@model List<EscapeRoomReviews.ViewModels.EscapeRoomIndexViewModel>

@{
    ViewData["Title"] = "Escape Rooms";

    var sobeCount = Model.Count;
    var gradoviCount = Model.Select(m => m.City).Distinct().Count();

    var selectedCities = new HashSet<string>(
        (ViewData["SelectedCities"] as List<string>) ?? new List<string>(),
        StringComparer.OrdinalIgnoreCase);
    var selectedDifficulties = new HashSet<string>(
        (ViewData["SelectedDifficulties"] as List<string>) ?? new List<string>(),
        StringComparer.OrdinalIgnoreCase);
    var selectedThemes = new HashSet<string>(
        (ViewData["SelectedThemes"] as List<string>) ?? new List<string>(),
        StringComparer.OrdinalIgnoreCase);
    var selectedSort = (ViewData["SelectedSort"] as string) ?? "rating";

    var gradoviStats = Model.GroupBy(m => m.City).Select(g => new { Name = g.Key, Count = g.Count() });
    var tezinaStats = Model.GroupBy(m => m.Difficulty).Select(g => new { Name = g.Key, Count = g.Count() });
    var temaStats = Model.SelectMany(m => m.Themes).GroupBy(t => t.Name).Select(g => new { Name = g.Key, Count = g.Count() });
}

<div class="row mb-5 mt-4">
    <div class="col-12">
        <div class="hero-section p-4 p-md-5 d-flex flex-column flex-md-row justify-content-between align-items-md-center shadow-lg" style="background-color: var(--primary-deep-green); color: white; border-radius: 16px; border: none;">
            <div class="mb-4 mb-md-0">
                <h1 class="hero-title fw-bold mb-3" style="color: white; font-size: 2.75rem; letter-spacing: -0.02em;">Pronađi svoju sljedeću avanturu</h1>
                <p class="mb-0 fs-5" style="color: rgba(255,255,255,0.85); font-weight: 400;">Pregledaj, usporedi i odaberi escape room koji<br />odgovara tvojoj ekipi.</p>
            </div>
            <div class="d-flex text-center gap-3 gap-md-4">
                <div class="stat-box p-4" style="background-color: rgba(255,255,255,0.1); border: 1px solid rgba(255,255,255,0.2); border-radius: 12px; min-width: 130px; backdrop-filter: blur(10px);">
                    <h2 class="stat-number fw-bold mb-1" style="color: white; font-size: 2.5rem;">@sobeCount</h2>
                    <small class="fw-medium text-uppercase" style="color: rgba(255,255,255,0.9); font-size: 0.85rem; letter-spacing: 1px;">Sobe</small>
                </div>
                <div class="stat-box p-4" style="background-color: rgba(255,255,255,0.1); border: 1px solid rgba(255,255,255,0.2); border-radius: 12px; min-width: 130px; backdrop-filter: blur(10px);">
                    <h2 class="stat-number fw-bold mb-1" style="color: white; font-size: 2.5rem;">@gradoviCount</h2>
                    <small class="fw-medium text-uppercase" style="color: rgba(255,255,255,0.9); font-size: 0.85rem; letter-spacing: 1px;">Gradovi</small>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="row">
    <!-- Sidebar: FILTRI -->
    <div class="col-lg-3 mb-4">
        <div class="escape-card shadow-sm p-4">
            <h6 class="text-uppercase fw-bold text-muted mb-4" style="letter-spacing: 1px;">Filtri</h6>

            <form method="get" id="filtersForm">
                <!-- Grad -->
                <div class="mb-4">
                    <h6 class="fw-bold mb-3">Grad</h6>
                    @foreach (var grad in gradoviStats)
                    {
                        <div class="form-check d-flex justify-content-between align-items-center mb-2">
                            <div>
                                <input class="form-check-input custom-checkbox" type="checkbox" name="city" value="@grad.Name" id="grad_@grad.Name" @(selectedCities.Contains(grad.Name) ? "checked" : null)>
                                <label class="form-check-label text-secondary" for="grad_@grad.Name">
                                    @grad.Name
                                </label>
                            </div>
                            <span class="badge rounded-pill bg-light text-muted">@grad.Count</span>
                        </div>
                    }
                </div>

                <!-- Težina -->
                <div class="mb-4">
                    <h6 class="fw-bold mb-3">Težina</h6>
                    @foreach (var tezina in tezinaStats)
                    {
                        <div class="form-check d-flex justify-content-between align-items-center mb-2">
                            <div>
                                <input class="form-check-input custom-checkbox" type="checkbox" name="difficulty" value="@tezina.Name" id="tezina_@tezina.Name" @(selectedDifficulties.Contains(tezina.Name) ? "checked" : null)>
                                <label class="form-check-label text-secondary" for="tezina_@tezina.Name">
                                    @tezina.Name
                                </label>
                            </div>
                            <span class="badge rounded-pill bg-light text-muted">@tezina.Count</span>
                        </div>
                    }
                </div>

                <!-- Tema -->
                <div class="mb-4">
                    <h6 class="fw-bold mb-3">Tema</h6>
                    @foreach (var tema in temaStats)
                    {
                        <div class="form-check d-flex justify-content-between align-items-center mb-2">
                            <div>
                                <input class="form-check-input custom-checkbox" type="checkbox" name="theme" value="@tema.Name" id="tema_@tema.Name" @(selectedThemes.Contains(tema.Name) ? "checked" : null)>
                                <label class="form-check-label text-secondary" for="tema_@tema.Name">
                                    @tema.Name
                                </label>
                            </div>
                            <span class="badge rounded-pill bg-light text-muted">@tema.Count</span>
                        </div>
                    }
                </div>

                <div class="d-flex flex-column gap-2 mt-4">
                    <button type="submit" class="btn text-white w-100 fw-bold" style="background-color: var(--primary-deep-green); border-radius: 8px; padding: 0.6rem;">Primijeni</button>
                    <a asp-action="Index" class="btn btn-outline-secondary w-100 fw-bold" style="border-radius: 8px; padding: 0.6rem;">Poništi filtar</a>
                </div>
            </form>
        </div>
    </div>

    <!-- Main Content: Sobe -->
    <div class="col-lg-9">
        <div class="d-flex flex-column flex-sm-row justify-content-between align-items-sm-center mb-4">
            <h3 class="fw-bold mb-3 mb-sm-0" style="color: #2b2b2b;">Escape Rooms <span class="text-muted fs-5">(@sobeCount)</span></h3>
            <select class="form-select w-auto fw-bold text-secondary shadow-sm border-0 bg-white" name="sort" form="filtersForm" id="sortSelect">
                @if (selectedSort == "rating")
                {
                    <option value="rating" selected>Sortiraj: Ocjena</option>
                }
                else
                {
                    <option value="rating">Sortiraj: Ocjena</option>
                }

                @if (selectedSort == "price-asc")
                {
                    <option value="price-asc" selected>Sortiraj: Cijena (najmanja)</option>
                }
                else
                {
                    <option value="price-asc">Sortiraj: Cijena (najmanja)</option>
                }

                @if (selectedSort == "price-desc")
                {
                    <option value="price-desc" selected>Sortiraj: Cijena (najveća)</option>
                }
                else
                {
                    <option value="price-desc">Sortiraj: Cijena (najveća)</option>
                }
            </select>
        </div>

        <script>
            (function () {
                var sortSelect = document.getElementById("sortSelect");
                var filtersForm = document.getElementById("filtersForm");
                if (!sortSelect || !filtersForm) return;
                sortSelect.addEventListener("change", function () {
                    filtersForm.submit();
                });
            })();
        </script>


        <div class="row row-cols-1 row-cols-md-2 g-4">
            @foreach (var room in Model)
            {
                <div class="col">
                    <a asp-action="Details" asp-route-id="@room.Id" style="text-decoration:none; color:inherit;">
                        <div class="card shadow-sm border-0 h-100 shadow-sm border-0 rounded-4 overflow-hidden room-card">
                            <div class="card-img-top d-flex justify-content-center align-items-center" style="height: 280px; position: relative; overflow: hidden; border-bottom: 1px solid #eee;">
                                @if (!string.IsNullOrEmpty(room.FirstPhotoUrl))
                                {
                                    <div style="position:absolute; inset:0; background-image:url('@room.FirstPhotoUrl'); background-size:cover; background-position:center; filter:blur(10px) brightness(0.75); transform:scale(1.1);"></div>
                                    <img src="@room.FirstPhotoUrl" alt="@room.Name" style="position:relative; z-index:1; max-width:100%; height:280px; object-fit:contain;" />
                                }
                                else
                                {
                                    <i class="bi bi-house-door" style="font-size: 3rem; color: #aaa;"></i>
                                }
                            </div>
                            <div class="card-body p-4">
                                <h5 class="fw-bold mb-3" style="color: #2b2b2b;">@room.Name</h5>

                                <div class="mb-3 d-flex flex-wrap gap-2">
                                    @{
                                        var diffBg = room.Difficulty switch {
                                            "Easy" => "#5aaa55",
                                            "Medium" => "#c9a83c",
                                            "Hard" => "#d45c5c",
                                            "Expert" => "var(--color-accent-purple)",
                                            _ => "#f1f3f5"
                                        };
                                        var diffText = "white";
                                    }
                                    <span class="badge rounded-pill border-0 px-3 py-2 fw-semibold" style="background-color: @diffBg; color: @diffText !important; font-size: 0.8rem; letter-spacing: 0.5px;">@room.Difficulty</span>
                                    <span class="badge rounded-pill border-0 px-3 py-2 fw-semibold" style="background-color: var(--color-bg-page); color: var(--primary-deep-green) !important; font-size: 0.8rem; letter-spacing: 0.5px;">@room.City</span>
                                    @foreach (var theme in room.Themes.Take(2))
                                    {
                                        <span class="badge rounded-pill border-0 px-3 py-2 fw-semibold" style="background-color: rgba(8,80,65,0.08); color: var(--primary-deep-green) !important; font-size: 0.8rem; letter-spacing: 0.5px;">
                                            @if (!string.IsNullOrEmpty(theme.IconUrl))
                                            {
                                                <i class="@theme.IconUrl me-1"></i>
                                            }
                                            @theme.Name
                                        </span>
                                    }
                                </div>

                                <div class="d-flex align-items-center mb-2">
                                    <div class="star-rating me-2" style="font-size: 0.9rem;">
                                        @{ var intRating = (int)Math.Round(room.AverageRating); }
                                        @for(int i = 0; i < 5; i++) {
                                            if (i < intRating) { <span>★</span> }
                                            else { <span style="color: #e4e5e9;">★</span> }
                                        }
                                    </div>
                                    <span class="fw-bold me-1">@room.AverageRating.ToString("0.0")</span>
                                    <span class="text-muted small">(@room.ReviewCount recenzije)</span>
                                </div>
                            </div>
                            <div class="card-footer bg-white border-top border-light p-4 d-flex justify-content-between align-items-center">
                                <div class="fw-bold fs-5">
                                    @Math.Round(room.Price) €
                                </div>
                                <div class="text-secondary fw-semibold small">
                                    @room.CompanyName
                                </div>
                            </div>
                        </div>
                    </a>
                </div>
            }
        </div>

    </div>
</div>

<script>
    (function () {
        var introKey = "escape-room-index-lock-intro-seen";
        var shouldShowIntro = true;

        try {
            shouldShowIntro = sessionStorage.getItem(introKey) !== "1";
            if (shouldShowIntro) {
                sessionStorage.setItem(introKey, "1");
                document.documentElement.classList.add("lock-intro-active");
            }
        } catch (error) {
            document.documentElement.classList.add("lock-intro-active");
        }

        if (!shouldShowIntro) {
            var overlay = document.getElementById("lock-overlay");
            if (overlay) {
                overlay.classList.add("hidden");
            }
        }
    })();
</script>

<div id="lock-overlay">
    <div id="lock-icon">
        <svg viewBox="0 0 100 120" xmlns="http://www.w3.org/2000/svg" width="80" height="80">
            <rect id="lock-body" x="10" y="50" width="80" height="60" rx="8" fill="#FFD700"/>
            <path id="lock-shackle" d="M30 50 V30 Q50 5 70 30 V50" fill="none" stroke="#FFD700" stroke-width="10" stroke-linecap="round"/>
            <circle cx="50" cy="80" r="8" fill="#085041"/>
            <rect x="46" y="80" width="8" height="12" rx="2" fill="#085041"/>
        </svg>
        <p id="lock-text">Dobrodošli</p>
    </div>
</div>

@section Scripts {
    <script>
        document.addEventListener("DOMContentLoaded", function () {
            var cardsRow = document.querySelector(".row.row-cols-1");
            if (!cardsRow) return;

            var cards = cardsRow.querySelectorAll(".col");
            cards.forEach(function (card, index) {
                card.style.animationDelay = (index * 80) + "ms";
                card.classList.add("card-enter");
            });
        });

        (function () {
            var overlay = document.getElementById("lock-overlay");
            if (!overlay || !document.documentElement.classList.contains("lock-intro-active")) return;

            setTimeout(function () {
                overlay.classList.add("hidden");
                document.documentElement.classList.remove("lock-intro-active");
            }, 1200);
        })();
    </script>
}







