@model List<EscapeRoomReviews.ViewModels.EscapeRoomIndexViewModel>

@{
    ViewData["Title"] = "Escape Rooms";

    var sobeCount = Model.Count;
    var gradoviCount = Model.Select(m => m.City).Distinct().Count();

    var selectedCities = new HashSet<string>(
        (ViewData["SelectedCities"] as List<string>) ?? new List<string>(),
        StringComparer.OrdinalIgnoreCase);
    var selectedDifficulties = new HashSet<string>(
        (ViewData["SelectedDifficulties"] as List<string>) ?? new List<string>(),
        StringComparer.OrdinalIgnoreCase);
    var selectedThemes = new HashSet<string>(
        (ViewData["SelectedThemes"] as List<string>) ?? new List<string>(),
        StringComparer.OrdinalIgnoreCase);
    var selectedSort = (ViewData["SelectedSort"] as string) ?? "rating";

    var gradoviStats = Model.GroupBy(m => m.City).Select(g => new { Name = g.Key, Count = g.Count() });
    var tezinaStats = Model.GroupBy(m => m.Difficulty).Select(g => new { Name = g.Key, Count = g.Count() });
    var temaStats = Model.SelectMany(m => m.Themes).GroupBy(t => t).Select(g => new { Name = g.Key, Count = g.Count() });
}

<div class="row mb-5">
    <div class="col-12">
        <div class="hero-section p-4 p-md-5 d-flex flex-column flex-md-row justify-content-between align-items-md-center shadow-sm">
            <div class="mb-4 mb-md-0">
                <h1 class="hero-title fw-bold mb-2">Pronađi svoju sljedeću avanturu</h1>
                <p class="text-muted mb-0 fs-5">Pregledaj, usporedi i odaberi escape room koji<br />odgovara tvojoj ekipi.</p>
            </div>
            <div class="d-flex text-center gap-4 gap-md-5">
                <div class="stat-box p-3">
                    <h2 class="stat-number fw-bold mb-0">@sobeCount</h2>
                    <small class="text-muted fw-semibold">Sobe</small>
                </div>
                <div class="stat-box p-3">
                    <h2 class="stat-number fw-bold mb-0">@gradoviCount</h2>
                    <small class="text-muted fw-semibold">Gradovi</small>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="row">
    <!-- Sidebar: FILTRI -->
    <div class="col-lg-3 mb-4">
        <div class="escape-card shadow-sm p-4">
            <h6 class="text-uppercase fw-bold text-muted mb-4" style="letter-spacing: 1px;">Filtri</h6>

            <form method="get" id="filtersForm">
                <!-- Grad -->
                <div class="mb-4">
                    <h6 class="fw-bold mb-3">Grad</h6>
                    @foreach (var grad in gradoviStats)
                    {
                        <div class="form-check d-flex justify-content-between align-items-center mb-2">
                            <div>
                                <input class="form-check-input custom-checkbox" type="checkbox" name="city" value="@grad.Name" id="grad_@grad.Name" @(selectedCities.Contains(grad.Name) ? "checked" : null)>
                                <label class="form-check-label text-secondary" for="grad_@grad.Name">
                                    @grad.Name
                                </label>
                            </div>
                            <span class="badge rounded-pill bg-light text-muted">@grad.Count</span>
                        </div>
                    }
                </div>

                <!-- Težina -->
                <div class="mb-4">
                    <h6 class="fw-bold mb-3">Težina</h6>
                    @foreach (var tezina in tezinaStats)
                    {
                        <div class="form-check d-flex justify-content-between align-items-center mb-2">
                            <div>
                                <input class="form-check-input custom-checkbox" type="checkbox" name="difficulty" value="@tezina.Name" id="tezina_@tezina.Name" @(selectedDifficulties.Contains(tezina.Name) ? "checked" : null)>
                                <label class="form-check-label text-secondary" for="tezina_@tezina.Name">
                                    @tezina.Name
                                </label>
                            </div>
                            <span class="badge rounded-pill bg-light text-muted">@tezina.Count</span>
                        </div>
                    }
                </div>

                <!-- Tema -->
                <div class="mb-4">
                    <h6 class="fw-bold mb-3">Tema</h6>
                    @foreach (var tema in temaStats)
                    {
                        <div class="form-check d-flex justify-content-between align-items-center mb-2">
                            <div>
                                <input class="form-check-input custom-checkbox" type="checkbox" name="theme" value="@tema.Name" id="tema_@tema.Name" @(selectedThemes.Contains(tema.Name) ? "checked" : null)>
                                <label class="form-check-label text-secondary" for="tema_@tema.Name">
                                    @tema.Name
                                </label>
                            </div>
                            <span class="badge rounded-pill bg-light text-muted">@tema.Count</span>
                        </div>
                    }
                </div>

                <div class="d-flex gap-2">
                    <button type="submit" class="btn btn-sm btn-dark">Primijeni</button>
                    <a asp-action="Index" class="btn btn-sm btn-outline-secondary">Reset</a>
                </div>
            </form>
        </div>
    </div>

    <!-- Main Content: Sobe -->
    <div class="col-lg-9">
        <div class="d-flex flex-column flex-sm-row justify-content-between align-items-sm-center mb-4">
            <h3 class="fw-bold mb-3 mb-sm-0" style="color: #2b2b2b;">Escape Rooms <span class="text-muted fs-5">(@sobeCount)</span></h3>
            <select class="form-select w-auto fw-bold text-secondary shadow-sm border-0 bg-white" name="sort" form="filtersForm" id="sortSelect">
                @if (selectedSort == "rating")
                {
                    <option value="rating" selected>Sortiraj: Ocjena</option>
                }
                else
                {
                    <option value="rating">Sortiraj: Ocjena</option>
                }

                @if (selectedSort == "price-asc")
                {
                    <option value="price-asc" selected>Sortiraj: Cijena (najmanja)</option>
                }
                else
                {
                    <option value="price-asc">Sortiraj: Cijena (najmanja)</option>
                }

                @if (selectedSort == "price-desc")
                {
                    <option value="price-desc" selected>Sortiraj: Cijena (najveća)</option>
                }
                else
                {
                    <option value="price-desc">Sortiraj: Cijena (najveća)</option>
                }
            </select>
        </div>

        <script>
            (function () {
                var sortSelect = document.getElementById("sortSelect");
                var filtersForm = document.getElementById("filtersForm");
                if (!sortSelect || !filtersForm) return;
                sortSelect.addEventListener("change", function () {
                    filtersForm.submit();
                });
            })();
        </script>

        <div class="row row-cols-1 row-cols-md-2 g-4">
            @foreach (var room in Model)
            {
                <div class="col">
                    <a asp-action="Details" asp-route-id="@room.Id" style="text-decoration:none; color:inherit;">
                        <div class="card h-100 shadow-sm border-0 rounded-4 overflow-hidden room-card">
                            <div class="card-img-top bg-light d-flex justify-content-center align-items-center" style="height: 160px; font-size: 3rem; background: linear-gradient(135deg, #fdfdfd 0%, #f0f0f0 100%); border-bottom: 1px solid #eee;">
                                @if (room.Themes.Contains("Sci-Fi")) { <span>🚀</span> }
                                else if (room.Themes.Contains("Horror")) { <span>🏚️</span> }
                                else { <span>🔬</span> }
                            </div>
                            <div class="card-body p-4">
                                <h5 class="fw-bold mb-3" style="color: #2b2b2b;">@room.Name</h5>
                                
                                <div class="mb-3 d-flex flex-wrap gap-2">
                                    @{
                                        var diffBg = room.Difficulty switch {
                                            "Easy" => "#eef9ed",
                                            "Medium" => "#faeed7",
                                            "Hard" => "#fceced",
                                            "Expert" => "#f5ecfa",
                                            _ => "#f1f3f5"
                                        };
                                        var diffText = room.Difficulty switch {
                                            "Easy" => "#155e34",
                                            "Medium" => "#603b12",
                                            "Hard" => "#a6292a",
                                            "Expert" => "#5c3194",
                                            _ => "#495057"
                                        };
                                    }
                                    <span class="badge rounded-pill border-0 px-3 py-2" style="background-color: @diffBg; color: @diffText !important; font-size: 0.85rem;">@room.Difficulty</span>
                                    <span class="badge rounded-pill border-0 px-3 py-2" style="background-color: #e7f5f0; color: #144e43 !important; font-size: 0.85rem;">@room.City</span>
                                    @foreach (var theme in room.Themes.Take(2))
                                    {
                                        <span class="badge rounded-pill border-0 px-3 py-2" style="background-color: #f1eefb; color: #29255a !important; font-size: 0.85rem;">@theme</span>
                                    }
                                </div>
                                
                                <div class="d-flex align-items-center mb-2">
                                    <div class="star-rating me-2" style="font-size: 0.9rem;">
                                        @{ var intRating = (int)Math.Round(room.AverageRating); }
                                        @for(int i = 0; i < 5; i++) {
                                            if (i < intRating) { <span>★</span> }
                                            else { <span style="color: #e4e5e9;">★</span> }
                                        }
                                    </div>
                                    <span class="fw-bold me-1">@room.AverageRating.ToString("0.0")</span>
                                    <span class="text-muted small">(@room.ReviewCount recenzije)</span>
                                </div>
                            </div>
                            <div class="card-footer bg-white border-top border-light p-4 d-flex justify-content-between align-items-center">
                                <div class="fw-bold fs-5">
                                    @Math.Round(room.Price) €
                                </div>
                                <div class="text-secondary fw-semibold small">
                                    @room.CompanyName
                                </div>
                            </div>
                        </div>
                    </a>
                </div>
            }
        </div>
    </div>
</div>





