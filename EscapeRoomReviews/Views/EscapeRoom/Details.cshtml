@model EscapeRoomReviews.Models.Domain.EscapeRoom
@{
    ViewData["Title"] = Model.Name;
    ViewData["BreadcrumbTitle"] = Model.Name;
    ViewData["BreadcrumbParent"] = "Sobe";
    ViewData["BreadcrumbParentAction"] = "Index";
    ViewData["BreadcrumbParentController"] = "EscapeRoom";
}

<div class="container mt-4 mb-5 p-4 p-md-5" style="background-color: var(--color-bg-page); border-radius: 16px;">
    <!-- 1. Header -->
    <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center mb-5 gap-3">
        <h1 class="fw-bold mb-0" style="color: var(--primary-deep-green); font-size: 2.5rem; letter-spacing: -0.02em;">@Model.Name</h1>
        <a asp-action="Index" class="btn fw-bold px-4 py-2" style="background-color: var(--primary-deep-green); color: white; border-radius: 8px;">← Natrag na popis</a>
    </div>

    <!-- 2. Info Row -->
    <div class="card shadow-sm border-0 mb-5 border-0 shadow-sm" style="border-radius: 12px; overflow: hidden;">
        <div class="card-body p-4 d-flex flex-wrap gap-4 align-items-center bg-white">
            <span class="badge fw-bold" style="background-color: var(--color-accent-pink); color: white; font-size: 0.95rem; padding: 0.6em 1em; letter-spacing: 0.5px; border-radius: 6px;">
                @Model.Difficulty
            </span>
            <span class="fw-semibold" style="color: var(--primary-deep-green); font-size: 1.05rem;">
                <i class="me-1">📍</i> @Model.Location?.City
            </span>
            <span class="fw-semibold" style="color: var(--primary-deep-green); font-size: 1.05rem;">
                <i class="me-1">👥</i> Max igrača: @Model.MaxPlayers
            </span>
            <span class="fw-semibold" style="color: var(--primary-deep-green); font-size: 1.05rem;">
                <i class="me-1">💵</i> @Model.Price €
            </span>
            <span class="fw-semibold" style="font-size: 1.05rem;">
                <i class="me-1">🏢</i>
                <a href="@Model.Company?.Website" target="_blank" class="text-decoration-none" style="color: var(--primary-deep-green); border-bottom: 2px solid var(--color-accent-peach); transition: border-color 0.2s;">
                    @Model.Company?.Name
                </a>
            </span>
        </div>
    </div>

    <!-- 3. Description & Themes -->
    <div class="row mb-5">
        <div class="col-lg-8 mb-4 mb-lg-0">
            <h3 class="fw-bold mb-4 text-primary-custom">O sobi</h3>
            <p class="fs-5" style="color: #4a4a4a; line-height: 1.7;">@Model.Description</p>
        </div>
        <div class="col-lg-4">
            <div class="p-4 bg-white shadow-sm" style="border-radius: 12px;">
                <h4 class="fw-bold mb-3 text-primary-custom">Teme</h4>
                <div class="d-flex flex-wrap gap-2">
                    @if (Model.Themes != null && Model.Themes.Any())
                    {
                        foreach (var theme in Model.Themes)
                        {
                            <span class="badge" style="background-color: var(--color-accent-peach); color: var(--primary-deep-green); font-size: 0.9rem; padding: 0.6em 1.2em; border-radius: 6px; font-weight: 600;">
                                @if (!string.IsNullOrEmpty(theme.IconUrl))
                                {
                                    <i class="@theme.IconUrl me-1"></i>
                                }
                                @theme.Name
                            </span>
                        }
                    }
                    else
                    {
                        <span class="text-muted">Nema definiranih tema.</span>
                    }
                </div>
            </div>
        </div>
    </div>

    <!-- 5. Reviews Section -->
    <div class="mb-5">
        <h3 class="fw-bold mb-4" style="color: var(--primary-deep-green); border-bottom: 3px solid var(--color-accent-pink); padding-bottom: 0.5rem; display: inline-block;">
            Recenzije (@(Model.Reviews?.Count ?? 0))
        </h3>
        
        @if (Model.Reviews != null && Model.Reviews.Any())
        {
            <div class="row row-cols-1 g-4">
                @foreach (var review in Model.Reviews)
                {
                    <div class="col">
                        <div class="card shadow-sm border-0 border-0 shadow-sm h-100" style="border-radius: 12px; transition: transform 0.2s;">
                            <div class="card-body p-4 bg-white" style="border-radius: 12px;">
                                <div class="d-flex justify-content-between align-items-center mb-3">
                                    <div class="d-flex align-items-center gap-2">
                                        <strong style="color: var(--primary-deep-green); font-size: 1.15rem; letter-spacing: 0.5px;">@review.User?.Username</strong>
                                        @if (review.IsVerified)
                                        {
                                            <span class="badge fw-bold" style="background-color: var(--color-accent-rose); color: var(--primary-deep-green); font-size: 0.75rem; letter-spacing: 0.5px; padding: 0.4em 0.8em; border-radius: 4px;">
                                                ✓ Verificirano
                                            </span>
                                        }
                                    </div>
                                    <div class="text-secondary small fw-medium">
                                        @review.CreatedAt.ToString("MMM dd, yyyy")
                                    </div>
                                </div>
                                <div class="mb-3" style="font-size: 1.25rem;">
                                    @for (int i = 1; i <= 5; i++)
                                    {
                                        if (i <= review.Rating)
                                        {
                                            <span style="color: var(--color-accent-pink);">★</span>
                                        }
                                        else
                                        {
                                            <span style="color: #e4e5e9;">★</span>
                                        }
                                    }
                                </div>
                                <p class="mb-0 fs-6" style="color: #4a4a4a; line-height: 1.6;">@review.Comment</p>
                            </div>
                        </div>
                    </div>
                }
            </div>
        }
        else
        {
            <div class="alert shadow-sm" style="background-color: white; border-radius: 12px; border: none; border-left: 5px solid var(--color-accent-pink); color: #4a4a4a; padding: 1.5rem;">
                Trenutno nema recenzija za ovu sobu. Budi prvi!
            </div>
        }
    </div>
</div>







