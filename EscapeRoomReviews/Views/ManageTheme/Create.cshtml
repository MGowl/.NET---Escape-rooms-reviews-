@model EscapeRoomReviews.Models.Forms.ThemeCreateModel

@{
    ViewData["Title"] = "Nova tema";
}

<div class="mb-4">
    <h1 class="display-6 fw-bold text-primary-custom">Nova tema</h1>
    <p class="text-muted">Unesite podatke za novu temu.</p>
</div>

<form asp-action="Create" method="post" class="card shadow-sm border-0 p-4">
    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

    <div class="mb-3">
        <label asp-for="Name" class="form-label">Naziv</label>
        <input asp-for="Name" class="form-control" />
        <span asp-validation-for="Name" class="text-danger small"></span>
    </div>

    <div class="mb-4">
        <label asp-for="IconUrl" class="form-label">Icon URL</label>
        <input asp-for="IconUrl" class="form-control" />
        <span asp-validation-for="IconUrl" class="text-danger small"></span>
    </div>

    <div class="d-flex gap-2">
        <button type="submit" class="btn btn-primary fw-semibold">Spremi</button>
        <a asp-action="Index" class="btn btn-outline-secondary">Odustani</a>
    </div>
</form>
