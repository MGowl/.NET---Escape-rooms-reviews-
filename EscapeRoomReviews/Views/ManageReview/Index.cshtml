@model IEnumerable<EscapeRoomReviews.ViewModels.ReviewIndexViewModel>

@{
    ViewData["Title"] = "Recenzije";
}

<div class="d-flex flex-column flex-sm-row justify-content-between align-items-sm-center mb-4">
    <div>
        <h1 class="display-6 fw-bold text-primary-custom mb-1">Recenzije</h1>
        <p class="text-muted mb-0">Popis svih aktivnih recenzija.</p>
    </div>
    <a asp-controller="ManageReview" asp-action="Create" class="btn btn-primary fw-semibold mt-3 mt-sm-0">
        + Nova recenzija
    </a>
</div>

<div class="table-responsive">
    <table class="table table-striped align-middle">
        <thead class="table-light">
            <tr>
                <th>Id</th>
                <th>Soba</th>
                <th>Korisnik</th>
                <th>Ocjena</th>
                <th>Komentar</th>
                <th>Datum</th>
                <th>Verificiran</th>
                <th class="text-end">Akcije</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var review in Model)
            {
                <tr>
                    <td>@review.Id</td>
                    <td>@review.RoomName</td>
                    <td>@review.Username</td>
                    <td>@review.Rating</td>
                    <td class="text-truncate" style="max-width: 260px;">@review.Comment</td>
                    <td>@review.CreatedAt.ToString("dd.MM.yyyy.")</td>
                    <td>
                        @if (review.IsVerified)
                        {
                            <span class="badge bg-success">Da</span>
                        }
                        else
                        {
                            <span class="badge bg-secondary">Ne</span>
                        }
                    </td>
                    <td class="text-end">
                        <a asp-controller="ManageReview" asp-action="Edit" asp-route-id="@review.Id" class="btn btn-sm btn-outline-primary me-2">Edit</a>
                        <form asp-controller="ManageReview" asp-action="Delete" method="post" class="d-inline">
                            <input type="hidden" name="id" value="@review.Id" />
                            <button type="submit" class="btn btn-sm btn-outline-danger">Delete</button>
                        </form>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

@if (!Model.Any())
{
    <div class="alert alert-info">Trenutno nema dostupnih recenzija.</div>
}
@await Html.PartialAsync("_DeleteRowAnimation")
