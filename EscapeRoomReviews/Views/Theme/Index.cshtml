@model List<EscapeRoomReviews.ViewModels.ThemeIndexViewModel>

@{
    ViewData["Title"] = "Teme";
}

<div class="row mb-5">
    <div class="col-12">
        <div class="hero-stats bg-white rounded-4 p-4 p-md-5 d-flex flex-column flex-md-row justify-content-between align-items-md-center shadow-sm" style="border-top: 4px solid var(--primary-deep-green);">
            <div class="mb-4 mb-md-0">
                <h1 class="fw-bold mb-2 text-primary-custom">Teme soba</h1>
                <p class="text-muted mb-0 fs-5">Odaberite svoju omiljenu atmosferu.</p>
            </div>
            <div class="d-flex text-center gap-4 gap-md-5">
                <div>
                    <h2 class="fw-bold mb-0 text-primary-custom">@Model.Count</h2>
                    <small class="text-muted fw-semibold">Ukupno tema</small>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.addEventListener("DOMContentLoaded", function () {
            var rows = document.querySelectorAll(".row");
            if (!rows.length) return;
            var cardsRow = rows[rows.length - 1];
            if (!cardsRow) return;

            var cards = cardsRow.querySelectorAll(".col, [class*='col-']");
            cards.forEach(function (card, index) {
                card.style.animationDelay = (index * 80) + "ms";
                card.classList.add("card-enter");
            });
        });
    </script>
}

<div class="row">
    @foreach (var theme in Model)
    {
        <div class="col-md-6 col-lg-3 mb-4">
            <a asp-action="Details" asp-route-id="@theme.Id" style="text-decoration:none; color:inherit;">
                <div class="card shadow-sm border-0 h-100 rounded-4 text-center room-card bg-white">
                    <div class="card-body p-4 d-flex flex-column justify-content-center">
                        @if (!string.IsNullOrEmpty(theme.IconUrl))
                        {
                            <i class="@theme.IconUrl fs-1 mb-2 text-primary-custom d-block"></i>
                        }
                        <h4 class="fw-bold mb-3 text-primary-custom">@theme.Name</h4>
                        <span class="badge rounded-pill align-self-center py-2 px-3 fw-semibold shadow-sm mb-3 bg-white text-primary-custom border">
                            Broj soba: @theme.RoomCount
                        </span>
                        <span class="btn btn-outline-primary rounded-pill px-4 fw-semibold text-decoration-none" style="align-self: center;">Istraži</span>
                    </div>
                </div>
            </a>
        </div>
    }
</div>






