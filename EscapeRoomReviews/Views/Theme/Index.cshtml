@model List<EscapeRoomReviews.ViewModels.ThemeIndexViewModel>

@{
    ViewData["Title"] = "Teme";
}

<div class="row mb-5">
    <div class="col-12">
        <div class="hero-stats bg-white rounded-4 p-4 p-md-5 d-flex flex-column flex-md-row justify-content-between align-items-md-center shadow-sm" style="border-top: 4px solid var(--color-primary);">
            <div class="mb-4 mb-md-0">
                <h1 class="fw-bold mb-2" style="color: var(--color-primary);">Teme soba</h1>
                <p class="text-muted mb-0 fs-5">Odaberite svoju omiljenu atmosferu.</p>
            </div>
            <div class="d-flex text-center gap-4 gap-md-5">
                <div>
                    <h2 class="fw-bold mb-0" style="color: var(--color-primary);">@Model.Count</h2>
                    <small class="text-muted fw-semibold">Ukupno tema</small>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="row">
    @foreach (var theme in Model)
    {
        <div class="col-md-6 col-lg-3 mb-4">
            <a asp-action="Details" asp-route-id="@theme.Id" style="text-decoration:none; color:inherit;">
                <div class="card h-100 border-0 shadow-sm rounded-4 text-center room-card" style="background-color: var(--color-bg-soft); border-bottom: 4px solid var(--color-primary) !important;">
                    <div class="card-body p-4 d-flex flex-column justify-content-center">
                        <h4 class="fw-bold mb-3" style="color: var(--color-primary);">@theme.Name</h4>
                        <span class="badge rounded-pill align-self-center py-2 px-3 fw-semibold shadow-sm mb-3" style="background-color: white; color: var(--color-primary); border: 1px solid rgba(0,0,0,0.1);">
                            @theme.RoomCount soba
                        </span>
                        <span class="btn btn-outline-primary rounded-pill px-4 mt-auto fw-semibold" style="align-self: center;">Istrazi</span>
                    </div>
                </div>
            </a>
        </div>
    }
</div>




