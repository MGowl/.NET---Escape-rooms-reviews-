@model EscapeRoomReviews.Models.Domain.Theme

@{
    ViewData["Title"] = Model.Name;
    ViewData["BreadcrumbTitle"] = Model.Name;
    ViewData["BreadcrumbParent"] = "Teme";
    ViewData["BreadcrumbParentAction"] = "Index";
    ViewData["BreadcrumbParentController"] = "Theme";
}

<div class="container mt-4 mb-5 detail-container">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="text-primary-custom fw-bold mb-0">
            @if (!string.IsNullOrEmpty(Model.IconUrl))
            {
                <i class="@Model.IconUrl me-2"></i>
            }
            @Model.Name Mode
        </h1>
        <a asp-action="Index" class="btn fw-bold px-4 py-2" style="background-color: var(--primary-deep-green); color: white; border-radius: 8px;">← Natrag na popis</a>
    </div>

    <div class="row g-4 mt-2">
        @if (Model.EscapeRooms != null && Model.EscapeRooms.Any())
        {
            @foreach (var room in Model.EscapeRooms)
            {
                var reviewCount = room.Reviews?.Count ?? 0;
                var avgRating = reviewCount > 0 ? Math.Round(room.Reviews!.Average(r => r.Rating), 1) : 0;

                <div class="col-md-6 col-lg-4">
                    <a asp-controller="EscapeRoom" asp-action="Details" asp-route-id="@room.Id" class="card shadow-sm border-0 h-100 room-card p-3 text-decoration-none text-body">
                        <div class="d-flex justify-content-between align-items-start mb-2">
                            <h4 class="text-primary-custom fw-bold mb-0 text-truncate" title="@room.Name">@room.Name</h4>
                            <span class="badge bg-primary rounded-pill ms-2">@room.Difficulty</span>
                        </div>
                        
                        <div class="d-flex flex-wrap gap-3 text-muted mb-3">
                            @if (room.Location != null)
                            {
                                <div class="d-flex align-items-center gap-1">
                                    <i class="bi bi-geo-alt"></i> @room.Location.City
                                </div>
                            }
                            @if (room.Company != null)
                            {
                                <div class="d-flex align-items-center gap-1">
                                    <i class="bi bi-building"></i> @room.Company.Name
                                </div>
                            }
                        </div>

                        <div class="d-flex justify-content-between align-items-end mt-auto">
                            <div>
                                <strong class="fs-5 text-primary-custom">$@room.Price.ToString("0.00")</strong>
                            </div>
                            <div class="d-flex align-items-center">
                                <i class="bi bi-star-fill me-1" style="color: var(--color-accent-pink);"></i>
                                <span class="fw-bold fs-5">@(avgRating > 0 ? avgRating.ToString("0.0") : "N/A")</span>
                                <span class="text-muted ms-1 text-nowrap">(@reviewCount)</span>
                            </div>
                        </div>
                    </a>
                </div>
            }
        }
        else
        {
            <div class="col-12 py-5 text-center card shadow-sm border-0">
                <div class="mb-3">
                    <i class="bi bi-search text-muted" style="font-size: 3rem;"></i>
                </div>
                <h3 class="text-primary-custom">No mysteries here yet!</h3>
                <p class="text-muted fs-5">There are currently no escape rooms listed under the <strong>@Model.Name</strong> theme.</p>
                <a asp-controller="Theme" asp-action="Index" class="btn btn-primary mt-3">
                    Explore Other Themes
                </a>
            </div>
        }
    </div>
</div>







