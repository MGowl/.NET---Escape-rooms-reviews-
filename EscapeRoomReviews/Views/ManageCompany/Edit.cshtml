@model EscapeRoomReviews.Models.Forms.CompanyEditModel

@{
    ViewData["Title"] = "Uredi tvrtku";
}

<div class="mb-4">
    <h1 class="display-6 fw-bold text-primary-custom">Uredi tvrtku</h1>
    <p class="text-muted">Azurirajte podatke za tvrtku.</p>
</div>

<form asp-action="Edit" method="post" class="card shadow-sm border-0 p-4">
    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
    <input asp-for="Id" type="hidden" />

    <div class="mb-3">
        <label asp-for="Name" class="form-label">Naziv</label>
        <input asp-for="Name" class="form-control" />
        <span asp-validation-for="Name" class="text-danger small"></span>
    </div>

    <div class="mb-4">
        <label asp-for="Website" class="form-label">Web</label>
        <input asp-for="Website" class="form-control" />
        <span asp-validation-for="Website" class="text-danger small"></span>
    </div>

    <div class="d-flex gap-2">
        <button type="submit" class="btn btn-primary fw-semibold">Spremi promjene</button>
        <a asp-action="Index" class="btn btn-outline-secondary">Odustani</a>
    </div>
</form>
