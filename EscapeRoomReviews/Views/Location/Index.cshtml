@model List<EscapeRoomReviews.ViewModels.LocationIndexViewModel>

@{
    ViewData["Title"] = "Lokacije";
}

<div class="row mb-5">
    <div class="col-12">
        <div class="hero-stats bg-white rounded-4 p-4 p-md-5 d-flex flex-column flex-md-row justify-content-between align-items-md-center shadow-sm" style="border-top: 4px solid var(--primary-deep-green);">
            <div class="mb-4 mb-md-0">
                <h1 class="fw-bold mb-2 text-primary-custom">Lokacije</h1>
                <p class="text-muted mb-0 fs-5">Pregledajte sve dostupne lokacije escape roomova.</p>
            </div>
            <div class="d-flex text-center gap-4 gap-md-5">
                <div>
                    <h2 class="fw-bold mb-0 text-primary-custom">@Model.Count</h2>
                    <small class="text-muted fw-semibold">Ukupno lokacija</small>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.addEventListener("DOMContentLoaded", function () {
            var rows = document.querySelectorAll(".row");
            if (!rows.length) return;
            var cardsRow = rows[rows.length - 1];
            if (!cardsRow) return;

            var cards = cardsRow.querySelectorAll(".col, [class*='col-']");
            cards.forEach(function (card, index) {
                card.style.animationDelay = (index * 80) + "ms";
                card.classList.add("card-enter");
            });
        });
    </script>
}

<div class="row">
    @foreach (var location in Model)
    {
        <div class="col-md-6 col-lg-4 mb-4">
            <a asp-action="Details" asp-route-id="@location.Id" style="text-decoration:none; color:inherit;">
                <div class="card shadow-sm border-0 h-100 rounded-4 overflow-hidden room-card">
                    <div class="card-body p-4">
                        <h5 class="fw-bold mb-2 text-primary-custom">@location.City</h5>
                        <p class="text-muted small mb-3">
                            <i class="bi bi-geo-alt-fill me-1 text-primary-custom"></i> @location.Address, @location.PostalCode
                        </p>
                        <hr class="text-muted opacity-25">
                        <div class="d-flex justify-content-between align-items-center mt-auto">
                            <div class="d-flex flex-column">
                                <span class="text-muted small fw-semibold text-uppercase" style="letter-spacing: 0.5px;">Sobe</span>
                                <span class="fw-bold fs-5">@location.RoomCount</span>
                            </div>
                            <span class="btn btn-outline-primary rounded-pill px-4 fw-semibold text-decoration-none">Detalji</span>
                        </div>
                    </div>
                </div>
            </a>
        </div>
    }
</div>






