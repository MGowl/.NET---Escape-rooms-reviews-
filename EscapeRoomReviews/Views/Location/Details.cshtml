@model EscapeRoomReviews.Models.Domain.Location

@{
    ViewData["Title"] = $"{Model.City} Location";
    ViewData["BreadcrumbTitle"] = Model.City;
    ViewData["BreadcrumbParent"] = "Lokacije";
    ViewData["BreadcrumbParentAction"] = "Index";
    ViewData["BreadcrumbParentController"] = "Location";
}

<div class="row mb-4 align-items-center border-bottom pb-3">
    <div class="col-8">
        <h1 class="price-text mb-0" style="color: #004F32 !important;">@Model.City</h1>
    </div>
    <div class="col-4 text-end">
        <a asp-action="Index" class="btn btn-outline-secondary">
            &larr; Back to Locations
        </a>
    </div>
</div>

<div class="card mb-5 border-0 shadow-sm" style="background-color: #F4F4F4;">
    <div class="card-body p-4">
        <h5 class="card-title text-secondary mb-3 border-bottom pb-2">Location Information</h5>
        <div class="row">
            <div class="col-md-6 mb-2">
                <strong>Address:</strong> @Model.Address
            </div>
            <div class="col-md-6 mb-2">
                <strong>Postal Code:</strong> @Model.PostalCode
            </div>
            @if (Model.Latitude != 0 || Model.Longitude != 0)
            {
                <div class="col-12 mt-2">
                    <small class="text-muted">Coords: @Model.Latitude, @Model.Longitude</small>
                </div>
            }
        </div>
    </div>
</div>

<h3 class="mb-4" style="color: #004F32;">Escape Rooms at this Location</h3>

@if (Model.EscapeRooms == null || !Model.EscapeRooms.Any())
{
    <div class="alert text-center py-5 border-0" style="background-color: #F4F4F4; color: #555;">
        <i class="fs-1 bi-door-closed mb-3 d-block text-muted"></i>
        <h4>No escape rooms available</h4>
        <p class="mb-0">There are currently no escape rooms listed at this location.</p>
    </div>
}
else
{
    <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4">
        @foreach (var room in Model.EscapeRooms)
        {
            var averageRating = room.Reviews != null && room.Reviews.Any() 
                ? Math.Round(room.Reviews.Average(r => r.Rating), 1) 
                : 0.0;
            var reviewCount = room.Reviews?.Count ?? 0;

            <div class="col">
                <a asp-controller="EscapeRoom" asp-action="Details" asp-route-id="@room.Id" class="text-decoration-none text-body">
                    <div class="card h-100 shadow-sm border-0 escape-room-card" style="transition: transform 0.2s;">
                        <div class="card-body d-flex flex-column">
                        <div class="d-flex justify-content-between align-items-start mb-2">
                            <h5 class="card-title text-truncate fw-bold mb-0" style="color: #004F32;">@room.Name</h5>
                            <span class="badge" style="background-color: #FF8DA1; color: #fff;">@room.Difficulty</span>
                        </div>
                        
                        <p class="card-subtitle text-muted small mb-3">
                            by <strong>@(room.Company?.Name ?? "Unknown Company")</strong>
                        </p>

                        <div class="mt-auto d-flex justify-content-between align-items-center pt-3 border-top">
                            <div class="fw-bold fs-5">
                                @room.Price.ToString("C")
                            </div>
                            <div class="text-end">
                                @if (reviewCount > 0)
                                {
                                    <div class="d-flex align-items-center justify-content-end" style="color: #004F32;">
                                        <span class="fw-bold fs-5 me-1">@averageRating</span>
                                        <span class="star-rating">&#9733;</span>
                                    </div>
                                    <small class="text-muted d-block" style="font-size: 0.75rem;">(@reviewCount reviews)</small>
                                }
                                else
                                {
                                    <span class="text-muted small fst-italic">No reviews yet</span>
                                }
                            </div>
                        </div>
                    </div>
                </div>
                </a>
            </div>
        }
    </div>
}

<style>
    .escape-room-card:hover {
        transform: translateY(-5px);
        box-shadow: 0 .5rem 1rem rgba(0,0,0,.15)!important;
    }
</style>




