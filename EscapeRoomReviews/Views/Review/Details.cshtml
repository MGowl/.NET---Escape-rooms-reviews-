@model EscapeRoomReviews.Models.Domain.Review

@{
    ViewData["Title"] = "Detalji recenzije";
    ViewData["BreadcrumbTitle"] = "Recenzija";
    ViewData["BreadcrumbParent"] = "Recenzije";
    ViewData["BreadcrumbParentAction"] = "Index";
    ViewData["BreadcrumbParentController"] = "Review";
}

<div class="review-details-container" style="background-color: #F4F4F4; padding: 2rem; border-radius: 12px; max-width: 900px; margin: 0 auto; color: #333;">
    
    <!-- Header -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 style="color: #004F32; font-weight: bold; margin: 0;">Recenzija</h1>
        <a asp-action="Index" class="btn fw-bold" style="background-color: #004F32; color: #fff; border-radius: 8px; padding: 0.6rem 1.2rem; text-decoration: none;">
            &larr; Natrag na popis
        </a>
    </div>

    <!-- Info Row -->
    <div class="d-flex gap-3 mb-4 flex-wrap">
        @if (Model.IsVerified)
        {
            <span class="badge d-flex align-items-center" style="background-color: #004F32; color: white; padding: 0.6rem 1rem; font-size: 0.95rem; border-radius: 20px;">
                ✓ Verificirano
            </span>
        }
        <span class="badge d-flex align-items-center" style="background-color: #FFC2BA; color: #004F32; padding: 0.6rem 1rem; font-size: 0.95rem; border-radius: 20px;">
            Datum: @Model.CreatedAt.ToString("dd.MM.yyyy.")
        </span>
        <span class="badge d-flex align-items-center" style="background-color: #FF8DA1; color: white; padding: 0.6rem 1rem; font-size: 0.95rem; border-radius: 20px;">
            @Model.PlayersCount igrača
        </span>
    </div>

    <!-- Rating -->
    <div class="mb-4 p-4 text-center test-rating-box" style="background-color: white; border-radius: 12px; box-shadow: 0 4px 10px rgba(0,0,0,0.03);">
        <div style="font-size: 3rem; color: #FFD700; letter-spacing: 5px; line-height: 1;">
            @for (int i = 1; i <= 5; i++)
            {
                if (i <= Model.Rating)
                {
                    <span>★</span>
                }
                else
                {
                    <span style="color: #e4e4e4;">★</span>
                }
            }
        </div>
        <div style="font-size: 1.25rem; color: #004F32; font-weight: bold; margin-top: 15px;">@Model.Rating / 5</div>
    </div>

    <!-- Comment -->
    <div class="mb-4 p-4" style="background-color: white; border-radius: 12px; box-shadow: 0 4px 10px rgba(0,0,0,0.03); border-left: 6px solid #FF8DA1;">
        <p style="font-size: 1.15rem; line-height: 1.7; margin: 0; font-style: italic; color: #444;">"@Model.Comment"</p>
    </div>

    <div class="row g-4 d-flex">
        <!-- Escape Room Info -->
        <div class="col-md-6 d-flex">
            <div class="p-4 w-100" style="background-color: white; border-radius: 12px; box-shadow: 0 4px 10px rgba(0,0,0,0.03);">
                <h4 style="color: #004F32; border-bottom: 2px solid #F4F4F4; padding-bottom: 12px; margin-bottom: 16px; font-weight: bold;">Escape Room</h4>
                <h5 class="mb-4" style="font-size: 1.25rem;">
                    <a asp-controller="EscapeRoom" asp-action="Details" asp-route-id="@Model.EscapeRoom?.Id" style="color: #AD56C4; text-decoration: none; font-weight: bold; transition: opacity 0.2s;" onmouseover="this.style.opacity='0.8'" onmouseout="this.style.opacity='1'">
                        @(Model.EscapeRoom?.Name ?? "Nepoznato")
                    </a>
                </h5>
                <div class="d-flex flex-column gap-3 fs-6">
                    <div class="d-flex justify-content-between align-items-center">
                        <strong style="color: #666;">Težina</strong> 
                        <span class="badge" style="background-color: #004F32; padding: 0.5rem 0.8rem;">@(Model.EscapeRoom?.Difficulty.ToString())</span>
                    </div>
                    <div class="d-flex justify-content-between align-items-center">
                        <strong style="color: #666;">Grad</strong> 
                        <span style="font-weight: 500;">@(Model.EscapeRoom?.Location?.City ?? "Nepoznato")</span>
                    </div>
                    <div class="d-flex justify-content-between align-items-center">
                        <strong style="color: #666;">Cijena</strong> 
                        <span style="font-weight: 500; font-size: 1.1rem; color: #004F32;">@(Model.EscapeRoom?.Price.ToString("C"))</span>
                    </div>
                </div>
            </div>
        </div>

        <!-- Author Info -->
        <div class="col-md-6 d-flex">
            <div class="p-4 w-100" style="background-color: white; border-radius: 12px; box-shadow: 0 4px 10px rgba(0,0,0,0.03);">
                <h4 style="color: #004F32; border-bottom: 2px solid #F4F4F4; padding-bottom: 12px; margin-bottom: 16px; font-weight: bold;">Autor</h4>
                <div class="d-flex flex-column gap-3 fs-6">
                    <div class="d-flex justify-content-between align-items-center">
                        <strong style="color: #666;">Korisničko ime</strong> 
                        <span style="font-weight: 500;">@(Model.User?.Username)</span>
                    </div>
                    <div class="d-flex justify-content-between align-items-center">
                        <strong style="color: #666;">Email</strong> 
                        <a href="mailto:@(Model.User?.Email)" style="color: #004F32; text-decoration: none; font-weight: 500;">@(Model.User?.Email)</a>
                    </div>
                    <div class="d-flex justify-content-between align-items-center">
                        <strong style="color: #666;">Uloga</strong> 
                        <span class="badge" style="background-color: #FF9CE9; color: #004F32; padding: 0.5rem 0.8rem;">@(Model.User?.Role.ToString())</span>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>





