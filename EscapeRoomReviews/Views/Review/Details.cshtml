@model EscapeRoomReviews.Models.Domain.Review

@{
    ViewData["Title"] = "Detalji recenzije";
    ViewData["BreadcrumbTitle"] = "Recenzija";
    ViewData["BreadcrumbParent"] = "Recenzije";
    ViewData["BreadcrumbParentAction"] = "Index";
    ViewData["BreadcrumbParentController"] = "Review";
}

<div class="detail-container" style="max-width: 900px; margin: 0 auto;">
    
    <!-- Header -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="text-primary-custom fw-bold mb-0">Recenzija</h1>
        <a asp-action="Index" class="btn btn-primary fw-bold px-4 py-2">
            &larr; Natrag na popis
        </a>
    </div>

    <!-- Info Row -->
    <div class="d-flex gap-3 mb-4 flex-wrap">
        @if (Model.IsVerified)
        {
            <span class="badge detail-badge bg-primary d-flex align-items-center">
                ✓ Verificirano
            </span>
        }
        <span class="badge detail-badge bg-secondary d-flex align-items-center">
            Datum: @Model.CreatedAt.ToString("dd.MM.yyyy.")
        </span>
        <span class="badge detail-badge bg-primary d-flex align-items-center">
            @Model.PlayersCount igrača
        </span>
    </div>

    <!-- Rating -->
    <div class="mb-4 p-4 text-center card shadow-sm border-0">
        <div class="star-rating" style="font-size: 3rem; letter-spacing: 5px; line-height: 1;">
            @for (int i = 1; i <= 5; i++)
            {
                if (i <= Model.Rating)
                {
                    <span>★</span>
                }
                else
                {
                    <span style="color: #e4e4e4;">★</span>
                }
            }
        </div>
        <div class="text-primary-custom fw-bold" style="font-size: 1.25rem; margin-top: 15px;">@Model.Rating / 5</div>
    </div>

    <!-- Comment -->
    <div class="mb-4 p-4 card shadow-sm border-0" style="border-left: 6px solid var(--color-accent-pink);">
        <p class="mb-0" style="font-size: 1.15rem; line-height: 1.7; font-style: italic; color: #444;">"@Model.Comment"</p>
    </div>

    <div class="row g-4 d-flex">
        <!-- Escape Room Info -->
        <div class="col-md-6 d-flex">
            <div class="p-4 w-100 card shadow-sm border-0">
                <h4 class="text-primary-custom fw-bold border-bottom pb-3 mb-3">Escape Room</h4>
                <h5 class="mb-4" style="font-size: 1.25rem;">
                    <a asp-controller="EscapeRoom" asp-action="Details" asp-route-id="@Model.EscapeRoom?.Id" class="link-accent fw-bold" onmouseover="this.style.opacity='0.8'" onmouseout="this.style.opacity='1'">
                        @(Model.EscapeRoom?.Name ?? "Nepoznato")
                    </a>
                </h5>
                <div class="d-flex flex-column gap-3 fs-6">
                    <div class="d-flex justify-content-between align-items-center">
                        <strong style="color: #666;">Težina</strong> 
                        <span class="badge bg-primary">@(Model.EscapeRoom?.Difficulty.ToString())</span>
                    </div>
                    <div class="d-flex justify-content-between align-items-center">
                        <strong style="color: #666;">Grad</strong> 
                        <span style="font-weight: 500;">@(Model.EscapeRoom?.Location?.City ?? "Nepoznato")</span>
                    </div>
                    <div class="d-flex justify-content-between align-items-center">
                        <strong style="color: #666;">Cijena</strong> 
                        <span class="text-primary-custom" style="font-weight: 500; font-size: 1.1rem;">@(Model.EscapeRoom?.Price.ToString("0.00")) €</span>
                    </div>
                </div>
            </div>
        </div>

        <!-- Author Info -->
        <div class="col-md-6 d-flex">
            <div class="p-4 w-100 card shadow-sm border-0">
                <h4 class="text-primary-custom fw-bold border-bottom pb-3 mb-3">Autor</h4>
                <div class="d-flex flex-column gap-3 fs-6">
                    <div class="d-flex justify-content-between align-items-center">
                        <strong style="color: #666;">Korisničko ime</strong>
                        <span style="font-weight: 500;">@(Model.AppUser?.UserName)</span>
                    </div>
                    <div class="d-flex justify-content-between align-items-center">
                        <strong style="color: #666;">Email</strong>
                        <a href="mailto:@(Model.AppUser?.Email)" class="link-accent" style="font-weight: 500;">@(Model.AppUser?.Email)</a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>







