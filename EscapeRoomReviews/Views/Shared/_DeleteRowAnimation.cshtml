    <script>
        (function () {
            var deleteForms = document.querySelectorAll("form.d-inline");

            deleteForms.forEach(function (form) {
                form.addEventListener("submit", function (e) {
                    e.preventDefault();

                    var row = form.closest("tr");
                    row.classList.add("row-deleting");

                    setTimeout(function () {
                        form.submit();
                    }, 400);
                });
            });
        })();
    </script>