<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - EscapeRoomReviews</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/flatpickr/dist/flatpickr.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/EscapeRoomReviews.styles.css" asp-append-version="true" />
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-lg navbar-toggleable-sm custom-navbar box-shadow mb-4">
            <div class="container">
                <a class="navbar-brand" asp-area="" asp-controller="EscapeRoom" asp-action="Index">ESCAPE ROOMS REVIEWS</a>
                <button class="navbar-toggler border-0" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1">
                        <li class="nav-item">
                            <a class="nav-link fw-semibold" asp-area="" asp-controller="EscapeRoom" asp-action="Index">Sobe</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link fw-semibold" asp-area="" asp-controller="Company" asp-action="Index">Tvrtke</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link fw-semibold" asp-area="" asp-controller="Location" asp-action="Index">Lokacije</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link fw-semibold" asp-area="" asp-controller="Theme" asp-action="Index">Teme</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link fw-semibold" asp-area="" asp-controller="Review" asp-action="Index">Recenzije</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link fw-semibold" asp-area="" asp-controller="User" asp-action="Index">Korisnici</a>
                        </li>
                        <li class="nav-item dropdown">
                            <a class="nav-link fw-semibold dropdown-toggle" href="#" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                                Upravljanje
                            </a>
                            <ul class="dropdown-menu">
                                <li><a class="dropdown-item" asp-area="" asp-controller="ManageEscapeRoom" asp-action="Index">Escape Rooms</a></li>
                                <li><a class="dropdown-item" asp-area="" asp-controller="ManageLocation" asp-action="Index">Lokacije</a></li>
                                <li><a class="dropdown-item" asp-area="" asp-controller="ManageCompany" asp-action="Index">Tvrtke</a></li>
                                <li><a class="dropdown-item" asp-area="" asp-controller="ManageTheme" asp-action="Index">Teme</a></li>
                                <li><a class="dropdown-item" asp-area="" asp-controller="ManageUser" asp-action="Index">Korisnici</a></li>
                                <li><a class="dropdown-item" asp-area="" asp-controller="ManageReview" asp-action="Index">Recenzije</a></li>
                            </ul>
                        </li>
                    </ul>
                    <partial name="_LoginPartial" />
                </div>
            </div>
        </nav>
    </header>
    <div class="container">
        @{
            var breadcrumbTitle = ViewData["BreadcrumbTitle"] as string;
            var breadcrumbParent = ViewData["BreadcrumbParent"] as string;
            var breadcrumbParentAction = ViewData["BreadcrumbParentAction"] as string;
            var breadcrumbParentController = ViewData["BreadcrumbParentController"] as string;
        }
        @if (!string.IsNullOrWhiteSpace(breadcrumbTitle))
        {
            <nav aria-label="breadcrumb" class="mb-4">
                <ol class="breadcrumb mb-0">
                    <li class="breadcrumb-item">
                        <a asp-controller="EscapeRoom" asp-action="Index">Pocetna</a>
                    </li>
                    @if (!string.IsNullOrWhiteSpace(breadcrumbParent) && !string.IsNullOrWhiteSpace(breadcrumbParentAction) && !string.IsNullOrWhiteSpace(breadcrumbParentController))
                    {
                        <li class="breadcrumb-item">
                            <a href="@Url.Action(breadcrumbParentAction, breadcrumbParentController)">@breadcrumbParent</a>
                        </li>
                    }
                    <li class="breadcrumb-item active" aria-current="page">@breadcrumbTitle</li>
                </ol>
            </nav>
        }
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted">
        <div class="container">
            &copy; 2026 - EscapeRoomReviews
        </div>
    </footer>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    @await Html.PartialAsync("_ValidationScriptsPartial")
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    <script src="https://cdn.jsdelivr.net/npm/flatpickr"></script>
    <script src="https://cdn.jsdelivr.net/npm/flatpickr/dist/l10n/hr.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>





