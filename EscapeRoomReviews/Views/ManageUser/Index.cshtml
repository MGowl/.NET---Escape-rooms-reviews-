@model List<EscapeRoomReviews.Models.Domain.User>

@{
    ViewData["Title"] = "Korisnici";
}

<div class="d-flex flex-column flex-sm-row justify-content-between align-items-sm-center mb-4">
    <div>
        <h1 class="display-6 fw-bold text-primary-custom mb-1">Korisnici</h1>
        <p class="text-muted mb-0">Administracija korisnika.</p>
    </div>
    <a asp-action="Create" class="btn btn-primary fw-semibold mt-3 mt-sm-0">
        + Novi korisnik
    </a>
</div>

<div class="table-responsive">
    <table class="table table-striped align-middle">
        <thead class="table-light">
            <tr>
                <th>Id</th>
                <th>Korisnicko ime</th>
                <th>Email</th>
                <th>Uloga</th>
                <th>Odigrane sobe</th>
                <th>Registriran</th>
                <th class="text-end">Akcije</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var user in Model)
            {
                <tr>
                    <td>@user.Id</td>
                    <td>@user.Username</td>
                    <td>@user.Email</td>
                    <td>@user.Role</td>
                    <td>@user.TotalRoomsPlayed</td>
                    <td>@user.RegisteredAt.ToString("dd.MM.yyyy.")</td>
                    <td class="text-end">
                        <a asp-action="Edit" asp-route-id="@user.Id" class="btn btn-sm btn-outline-primary me-2">Edit</a>
                        <form asp-action="Delete" method="post" class="d-inline">
                            <input type="hidden" name="id" value="@user.Id" />
                            <button type="submit" class="btn btn-sm btn-outline-danger">Delete</button>
                        </form>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

@if (!Model.Any())
{
    <div class="alert alert-info">Trenutno nema dostupnih korisnika.</div>
}
@await Html.PartialAsync("_DeleteRowAnimation")