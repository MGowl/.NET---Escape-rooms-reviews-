@model EscapeRoomReviews.Models.Forms.LocationCreateModel

@{
    ViewData["Title"] = "Nova lokacija";
}

<div class="mb-4">
    <h1 class="display-6 fw-bold text-primary-custom">Nova lokacija</h1>
    <p class="text-muted">Unesite podatke za novu lokaciju.</p>
</div>

<form asp-action="Create" method="post" class="card shadow-sm border-0 p-4">
    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

    <div class="mb-3">
        <label asp-for="City" class="form-label">Grad</label>
        <input asp-for="City" class="form-control" />
    </div>

    <div class="mb-3">
        <label asp-for="Address" class="form-label">Adresa</label>
        <input asp-for="Address" class="form-control" />
    </div>

    <div class="mb-3">
        <label asp-for="PostalCode" class="form-label">Postanski broj</label>
        <input asp-for="PostalCode" class="form-control" />
    </div>

    <div class="mb-3">
        <label asp-for="Latitude" class="form-label">Latitude</label>
        <input asp-for="Latitude" class="form-control" type="number" step="0.000001" />
    </div>

    <div class="mb-4">
        <label asp-for="Longitude" class="form-label">Longitude</label>
        <input asp-for="Longitude" class="form-control" type="number" step="0.000001" />
    </div>

    <div class="d-flex gap-2">
        <button type="submit" class="btn btn-primary fw-semibold">Spremi</button>
        <a asp-action="Index" class="btn btn-outline-secondary">Odustani</a>
    </div>
</form>
