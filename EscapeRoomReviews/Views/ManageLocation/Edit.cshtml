@model EscapeRoomReviews.Models.Forms.LocationEditModel

@{
    ViewData["Title"] = "Uredi lokaciju";
}

<div class="mb-4">
    <h1 class="display-6 fw-bold text-primary-custom">Uredi lokaciju</h1>
    <p class="text-muted">Azurirajte podatke za lokaciju.</p>
</div>

<form asp-action="Edit" method="post" class="card shadow-sm border-0 p-4">
    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
    <input asp-for="Id" type="hidden" />

    <div class="mb-3">
        <label asp-for="City" class="form-label">Grad</label>
        <input asp-for="City" class="form-control" />
        <span asp-validation-for="City" class="text-danger small"></span>
    </div>

    <div class="mb-3">
        <label asp-for="Address" class="form-label">Adresa</label>
        <input asp-for="Address" class="form-control" />
        <span asp-validation-for="Address" class="text-danger small"></span>
    </div>

    <div class="mb-3">
        <label asp-for="PostalCode" class="form-label">Postanski broj</label>
        <input asp-for="PostalCode" class="form-control" />
        <span asp-validation-for="PostalCode" class="text-danger small"></span>
    </div>

    <div class="mb-3">
        <label asp-for="Latitude" class="form-label">Latitude</label>
        <input asp-for="Latitude" class="form-control" type="number" step="0.000001" />
        <span asp-validation-for="Latitude" class="text-danger small"></span>
    </div>

    <div class="mb-4">
        <label asp-for="Longitude" class="form-label">Longitude</label>
        <input asp-for="Longitude" class="form-control" type="number" step="0.000001" />
        <span asp-validation-for="Longitude" class="text-danger small"></span>
    </div>

    <div class="d-flex gap-2">
        <button type="submit" class="btn btn-primary fw-semibold">Spremi promjene</button>
        <a asp-action="Index" class="btn btn-outline-secondary">Odustani</a>
    </div>
</form>
