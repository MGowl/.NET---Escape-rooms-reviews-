@model List<EscapeRoomReviews.ViewModels.UserIndexViewModel>

@{
    ViewData["Title"] = "Korisnici";
}

<div class="row mb-5">
    <div class="col-12">
        <div class="hero-stats bg-white rounded-4 p-4 p-md-5 d-flex flex-column flex-md-row justify-content-between align-items-md-center shadow-sm" style="border-top: 4px solid var(--primary-deep-green);">
            <div class="mb-4 mb-md-0">
                <h1 class="fw-bold mb-2 text-primary-custom">Korisnici</h1>
                <p class="text-muted mb-0 fs-5">Pregled registriranih korisnika platforme.</p>
            </div>
            <div class="d-flex text-center gap-4 gap-md-5">
                <div>
                    <h2 class="fw-bold mb-0 text-primary-custom">@Model.Count</h2>
                    <small class="text-muted fw-semibold">Ukupno korisnika</small>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.addEventListener("DOMContentLoaded", function () {
            var rows = document.querySelectorAll(".row");
            if (!rows.length) return;
            var cardsRow = rows[rows.length - 1];
            if (!cardsRow) return;

            var cards = cardsRow.querySelectorAll(".col, [class*='col-']");
            cards.forEach(function (card, index) {
                card.style.animationDelay = (index * 80) + "ms";
                card.classList.add("card-enter");
            });
        });
    </script>
}

<div class="row">
    @foreach (var user in Model)
    {
        <div class="col-md-6 col-lg-4 mb-4">
            <a asp-action="Details" asp-route-id="@user.Id" style="text-decoration:none; color:inherit;">
                <div class="card shadow-sm border-0 h-100 rounded-4 text-center room-card card-accent-top">
                    <div class="card-body p-4 d-flex flex-column justify-content-center">
                        <i class="bi bi-person-circle fs-1 mb-3 text-secondary" style="opacity: 0.5;"></i>
                        <h4 class="fw-bold mb-1 text-primary-custom">@user.DisplayName</h4>
                        <span class="text-muted small mb-3">@user.Email</span>
                        
                        <span class="badge rounded-pill align-self-center py-2 px-3 fw-semibold shadow-sm mb-4 bg-white text-primary-custom border">
                            @user.Role
                        </span>
                        
                        <div class="d-flex justify-content-between text-muted small px-3 mt-auto">
                            <div class="text-start">
                                <span class="fw-semibold text-uppercase" style="letter-spacing: 0.5px; font-size: 0.75rem;">Odigrane sobe</span><br>
                                <span class="fw-bold text-dark fs-5">@user.TotalRoomsPlayed</span>
                            </div>
                            <div class="text-end">
                                <span class="fw-semibold text-uppercase" style="letter-spacing: 0.5px; font-size: 0.75rem;">Pridružen/a</span><br>
                                <span class="fw-bold text-dark">@user.RegisteredAt.ToString("dd.MM.yyyy.")</span>
                            </div>
                        </div>
                    </div>
                </div>
            </a>
        </div>
    }
</div>






